{
  "framework": "vite",
  "buildCommand": "pip install -r requirements.txt && npm install && npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.py": {
      "runtime": "python@3.11"
    }
  },
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
